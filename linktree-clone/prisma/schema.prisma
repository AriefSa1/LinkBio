// Prisma schema untuk Linktree clone
// Dokumentasi: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  username   String   @unique
  email      String   @unique
  password   String // di-hash dengan bcrypt
  name       String?
  bio        String?  @db.VarChar(255)
  avatarUrl  String?  @db.VarChar(500)
  avatarData String?  @db.LongText // foto hasil upload (data URL base64)
  theme      String   @default("midnight")
  bgType     String   @default("theme") // "theme" | "color" | "image"
  bgColor    String?  @db.VarChar(32)
  bgImage    String?  @db.LongText // gambar latar hasil upload (data URL)
  cardMode   Boolean  @default(false)
  isAdmin    Boolean  @default(false)
  links      Link[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Link {
  id        String   @id @default(cuid())
  title     String
  url       String   @db.VarChar(500)
  icon      String?  @db.VarChar(32) // kunci ikon; null = deteksi otomatis
  active    Boolean  @default(true)
  order     Int      @default(0)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}
